# Public base URL where this app is served (used to build the OIDC redirect URI).
APP_BASE_URL=https://invites.example.com

# kanidm instance.
KANIDM_URL=https://account.loaf.moe

# OIDC client registered in kanidm (POST /v1/oauth2/_basic) for inviter login.
OIDC_CLIENT_ID=invites
OIDC_CLIENT_SECRET=change-me

# kanidm service account API token. The service account must be a member of
# idm_people_admins (required to create persons + mint credential reset tokens).
KANIDM_SERVICE_TOKEN=change-me

# kanidm group whose members are treated as admins (can manage all invitations).
KANIDM_ADMIN_GROUP=idm_admins

# SQLite database (created on first run).
DATABASE_URL=sqlite://invites.db?mode=rwc

# Credential reset token TTL in seconds (kanidm hard-caps at 86400).
RESET_TOKEN_TTL_SECS=3600

# Address the server binds to (read by dioxus::serve).
IP=0.0.0.0
PORT=8080
